<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/root_coordinator_layout"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:padding="@dimen/root_layout_standart_padding"
    tools:context=".presentation.view.bottomsheet.TransmitterBottomSheetDialogFragment">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/main_constraint_layout"
        android:layout_width="match_parent"
        android:layout_height="wrap_content">

        <TextView
            android:id="@+id/bottom_sheet_title_text_view"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/transmitter_part_title_text"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            android:textSize="@dimen/module_part_title_text_size"
            android:textColor="?attr/colorOnSurface"
            android:textStyle="bold"
            />

        <com.google.android.material.chip.ChipGroup
            android:id="@+id/rx_channel_selection_chip_group"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:chipSpacingHorizontal="@dimen/chip_group_horizontal_spacing"
            app:chipSpacingVertical="@dimen/chip_group_vertical_spacing"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toBottomOf="@+id/bottom_sheet_title_text_view"
            android:layout_marginTop="@dimen/margin_between_ch_icon_ornament"
            app:singleSelection="true"
            app:selectionRequired="false">

            <com.google.android.material.chip.Chip
                android:id="@+id/first_channel_selection_chip"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:checked="true"
                android:text="Канал 1"/>

            <com.google.android.material.chip.Chip
                android:id="@+id/second_channel_selection_chip"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Канал 2"/>

            <com.google.android.material.chip.Chip
                android:id="@+id/third_channel_selection_chip"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Канал 3"/>

            <com.google.android.material.chip.Chip
                android:id="@+id/fourth_channel_selection_chip"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Канал 4"/>

            <com.google.android.material.chip.Chip
                android:id="@+id/fifth_channel_selection_chip"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Канал 5"/>

        </com.google.android.material.chip.ChipGroup>

        <CheckBox
            android:id="@+id/switch_transmitter_on_check_box"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/transmitter_switch_check_box_text"
            android:checked="false"
            android:textColor="@color/checkbox_text_color_selector"
            app:layout_constraintTop_toBottomOf="@id/rx_channel_selection_chip_group"
            app:layout_constraintStart_toStartOf="parent"/>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/transmitter_params_send_button"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            android:text="@string/send_button_text"
            app:layout_constraintTop_toBottomOf="@+id/switch_transmitter_on_check_box" />

    </androidx.constraintlayout.widget.ConstraintLayout>

</androidx.coordinatorlayout.widget.CoordinatorLayout>